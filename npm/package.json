  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "scripts": {
    "build-bridge": "node scripts/build-bridge.js"
  },
  "files": [
    "lib/",
    "bin/",
    "README.md"
  ],
  "os": [
    "win32"
  ],
  "cpu": [
    "x64"
  ],
  "engines": {
    "node": ">=16"
  },
  "keywords": [
    "windows",
    "virtual-desktop",
    "electron",
    "spaces",
    "macos",
    "desktop"
  ],
  "license": "MIT"
}
